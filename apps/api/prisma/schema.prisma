// =========================
// DATABASE + CLIENT CONFIG
// =========================

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// ENUMS
// =========================

enum Role {
  super_admin
  regional_director
  site_supervisor
}

// =========================
// MODELS
// =========================

model Site {
  id               String    @id @default(uuid())
  code             String    @unique
  name             String
  tempPasswordHash String?
  createdAt        DateTime  @default(now())

  users            User[]
  auditLogs        AuditLog[]

  @@map("sites")
}

model User {
  id             String    @id @default(uuid())
  firstName      String?
  lastName       String?
  username       String    @unique
  email          String?
  internalEmail  String    @unique
  passwordHash   String
  role           Role
  siteId         String?
  site           Site?     @relation(fields: [siteId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  auditLogs      AuditLog[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  siteId    String
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
  site      Site @relation(fields: [siteId], references: [id])

  @@map("audit_logs")
}
