# API
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hartsystem
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=8h

# Clerk auth (API)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
# Just-in-time provisioning: unknown Clerk users are auto-added to this org.
CLERK_JIT_ORG_SLUG=faeheart-survey-co
CLERK_JIT_ROLE=super_admin
# Lockdown: when set, ONLY these emails may be auto-provisioned (comma-separated).
# Leave empty in local dev. Set in production to your team's emails.
CLERK_JIT_ALLOWED_EMAILS=

# Web
VITE_API_BASE_URL=http://localhost:4000/api/v1
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
